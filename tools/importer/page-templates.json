{
  "templates": [
    {
      "name": "homepage",
      "description": "Boeing homepage with hero video, news cards, product cards, roadblocks, feature cards, and mini tiles",
      "urls": [
        "https://www.boeing.com/"
      ],
      "blocks": [
        {
          "name": "hero-video",
          "selector": ".jumbotron.teaser",
          "sectionId": 1,
          "parse": "hero-video-parser"
        },
        {
          "name": "cards-news",
          "selector": "#section-e399d3f855",
          "sectionId": 2,
          "parse": "cards-news-parser",
          "sectionMetadata": {
            "style": "light"
          }
        },
        {
          "name": "cards-product",
          "selector": "#section-ea641b114c",
          "sectionId": 3,
          "parse": "cards-product-parser",
          "sectionMetadata": {
            "style": "light"
          }
        },
        {
          "name": "hero-roadblock",
          "selector": "#roadblock-image-text-3e99e7fb-7332-4a54-9bdf-00af32dc78d8",
          "sectionId": 4,
          "parse": "hero-roadblock-parser"
        },
        {
          "name": "cards-feature",
          "selector": "#section-beb9885678",
          "sectionId": 5,
          "parse": "cards-feature-parser",
          "sectionMetadata": {
            "style": "dark"
          }
        },
        {
          "name": "hero-roadblock",
          "selector": "#roadblock-image-text-ca5f7eaf-5575-4ad0-94ca-a6281a994777",
          "sectionId": 6,
          "parse": "hero-roadblock-parser"
        },
        {
          "name": "cards-feature",
          "selector": "section:has(#text-042f2d7ecb)",
          "sectionId": 7,
          "parse": "cards-feature-parser",
          "sectionMetadata": {
            "style": "dark"
          }
        },
        {
          "name": "cards-mini",
          "selector": "section:has(#text-042f2d7ecb)",
          "sectionId": 7,
          "parse": "cards-mini-parser",
          "sectionMetadata": {
            "style": "dark"
          }
        },
        {
          "name": "hero-roadblock",
          "selector": "#roadblock-image-text-11820dcd-037a-4d97-bed0-9144abaa10b3",
          "sectionId": 8,
          "parse": "hero-roadblock-parser",
          "variant": "right"
        }
      ]
    }
  ]
}
